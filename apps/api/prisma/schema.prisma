generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id        String    @id
  name      String?
  createdAt DateTime  @default(now())
  sessions  Session[]
}

model Session {
  id               String       @id
  projectId        String?
  projectName      String?
  agentName        String
  title            String?
  status           String       @default("running")
  startedAt        DateTime
  endedAt          DateTime?
  lastEventAt      DateTime
  metadata         String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  project          Project?     @relation(fields: [projectId], references: [id])
  spans            Span[]
  llmRequests      LlmRequest[]
  toolCalls        ToolCall[]
  usageMetrics     UsageMetric[]
  agentEvents      AgentEvent[]

  @@index([projectId, lastEventAt])
  @@index([lastEventAt])
  @@index([status])
}

model Span {
  id          String       @id
  sessionId   String
  parentSpanId String?
  type        String
  name        String
  status      String       @default("running")
  startedAt   DateTime
  endedAt     DateTime?
  durationMs  Int?
  errorMessage String?
  metadata    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  session     Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  parent      Span?        @relation("SpanChildren", fields: [parentSpanId], references: [id])
  children    Span[]       @relation("SpanChildren")
  llmRequest  LlmRequest?
  toolCall    ToolCall?
  agentEvents AgentEvent[]

  @@index([sessionId, startedAt, id])
  @@index([parentSpanId])
  @@index([type, status])
}

model LlmRequest {
  id                String       @id
  sessionId         String
  spanId            String       @unique
  provider          String
  model             String
  requestId         String?
  status            String
  startedAt         DateTime
  endedAt           DateTime?
  latencyMs         Int?
  promptTokens      Int          @default(0)
  completionTokens  Int          @default(0)
  cachedTokens      Int          @default(0)
  inputBytes        Int?
  outputBytes       Int?
  totalTokens       Int          @default(0)
  estimatedCostUsd  Float?
  finishReason      String?
  errorCode         String?
  errorMessage      String?
  metadata          String?
  session           Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  span              Span         @relation(fields: [spanId], references: [id], onDelete: Cascade)

  @@index([sessionId, startedAt])
  @@index([provider, model])
  @@index([status])
  @@index([startedAt])
}

model ToolCall {
  id                String       @id
  sessionId         String
  spanId            String       @unique
  toolName          String
  callId            String?
  status            String
  startedAt         DateTime
  endedAt           DateTime?
  latencyMs         Int?
  argumentsSummary  String?
  redactedArguments String?
  resultSummary     String?
  exitStatus        String?
  errorCode         String?
  errorMessage      String?
  session           Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  span              Span         @relation(fields: [spanId], references: [id], onDelete: Cascade)

  @@index([sessionId, startedAt])
  @@index([toolName])
  @@index([status])
  @@index([startedAt])
}

model UsageMetric {
  id                Int      @id @default(autoincrement())
  sessionId         String
  llmRequestId      String?
  provider          String
  model             String
  timestamp         DateTime
  promptTokens      Int      @default(0)
  completionTokens  Int      @default(0)
  cachedTokens      Int      @default(0)
  totalTokens       Int      @default(0)
  estimatedCostUsd  Float?
  session           Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([llmRequestId])
  @@index([sessionId, timestamp])
  @@index([provider, model])
  @@index([timestamp])
}

model AgentEvent {
  id          Int      @id @default(autoincrement())
  eventId     String   @unique
  sessionId   String
  spanId      String?
  type        String
  timestamp   DateTime
  agentName   String
  projectId   String?
  raw         String
  createdAt   DateTime @default(now())
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  span        Span?    @relation(fields: [spanId], references: [id], onDelete: SetNull)

  @@index([sessionId, timestamp, id])
  @@index([spanId])
  @@index([type, timestamp])
  @@index([projectId, timestamp])
}
