{
  "name": "argus-forge",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm -r --parallel --filter @argus-forge/api --filter @argus-forge/web dev",
    "build": "pnpm -r --filter @argus-forge/shared --filter @argus-forge/api --filter @argus-forge/web build",
    "typecheck": "pnpm -r typecheck",
    "typecheck:pi-extension": "pnpm --dir .pi/extensions/argus-forge typecheck",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "test": "pnpm --filter @argus-forge/api test",
    "issues:codex": "node scripts/handle-github-issues.mjs",
    "db:migrate": "pnpm --filter @argus-forge/shared build && pnpm --filter @argus-forge/api db:migrate",
    "db:generate": "pnpm --filter @argus-forge/api db:generate",
    "seed": "pnpm --filter @argus-forge/api seed"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
